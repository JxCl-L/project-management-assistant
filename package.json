{
  "name": "project-management-assistant",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:server": "npm run dev:rag-test --workspace=apps/server",
    "dev:client": "npm run dev --workspace=apps/client",
    "build:client": "npm run build --workspace=apps/client",
    "lint:client": "npm run lint --workspace=apps/client",
    "seed:server": "npm run seed --workspace=apps/server",
    "eval:rag": "npm run eval:rag --workspace=apps/server"
  }
}
