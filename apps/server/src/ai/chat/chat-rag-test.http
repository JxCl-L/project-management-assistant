@baseUrl = http://localhost:3001
@token = PASTE_TOKEN_HERE
@projectId = PASTE_PROJECT_ID_HERE

# ============================================================
# RAG Test — Project Atlas (fullstackTasks_rag_test)
# ============================================================
# Setup:
#   1. npm run dev:rag-test
#   2. Login below → copy token into @token above
#   3. GET /projects → copy Project Atlas _id into @projectId above
#   4. Run queries — ?debug=true shows retrieved chunks + scores
#   5. Results are pasted in chat-rag-test-result.http (gitignored)
# ============================================================

# ── 1. Login ─────────────────────────────────────────────────
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "alice@example.com",
  "password": "Password123#"
}

###

# ── 2. Get projects (find Project Atlas _id) ─────────────────
GET {{baseUrl}}/projects
Authorization: Bearer {{token}}

###

# ============================================================
# CATEGORY A — Specific date facts
# Facts exist only in task content, NOT in title/description.
# Good answer = correct date + correct task in _debug.retrieved.
# ============================================================

# A1. Outage start time
POST {{baseUrl}}/projects/{{projectId}}/chat?debug=true
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "messages": [{ "role": "user", "content": "What time did the January 15 outage start and how long did it last?" }]
}

###

# A2. Meeting date in content
POST {{baseUrl}}/projects/{{projectId}}/chat?debug=true
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "messages": [{ "role": "user", "content": "When was the API rate limiting design review meeting held?" }]
}

###

# A3. Go-live date
POST {{baseUrl}}/projects/{{projectId}}/chat?debug=true
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "messages": [{ "role": "user", "content": "What date did the Stripe integration go live in production?" }]
}

###

# A4. Date buried in content, different from task dueDate
POST {{baseUrl}}/projects/{{projectId}}/chat?debug=true
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "messages": [{ "role": "user", "content": "When did Marcus Chen's first PR get merged?" }]
}

###

# ============================================================
# CATEGORY B — Specific numbers and metrics
# ============================================================

# B1. Latency before/after fix
POST {{baseUrl}}/projects/{{projectId}}/chat?debug=true
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "messages": [{ "role": "user", "content": "What was the P95 search latency before and after the fix in January?" }]
}

###

# B2. Cost / budget fact
POST {{baseUrl}}/projects/{{projectId}}/chat?debug=true
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "messages": [{ "role": "user", "content": "How much did the Jenkins to GitHub Actions migration save per year?" }]
}

###

# B3. Load test numbers
POST {{baseUrl}}/projects/{{projectId}}/chat?debug=true
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "messages": [{ "role": "user", "content": "What were the load test results at 500 concurrent users?" }]
}

###

# B4. Stripe first-day numbers
POST {{baseUrl}}/projects/{{projectId}}/chat?debug=true
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "messages": [{ "role": "user", "content": "How many subscriptions were created on the first day Stripe launched?" }]
}

###

# ============================================================
# CATEGORY C — Person attribution
# ============================================================

# C1. Who ran load testing
POST {{baseUrl}}/projects/{{projectId}}/chat?debug=true
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "messages": [{ "role": "user", "content": "Who ran the load testing in February and what tool did they use?" }]
}

###

# C2. Who found the root cause
POST {{baseUrl}}/projects/{{projectId}}/chat?debug=true
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "messages": [{ "role": "user", "content": "Who identified the root cause of the auth token expiry bug and when?" }]
}

###

# ============================================================
# CATEGORY D — Multi-chunk within one task
# Good result = multiple chunks from the same task retrieved.
# ============================================================

# D1. Timeline spanning multiple paragraphs
POST {{baseUrl}}/projects/{{projectId}}/chat?debug=true
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "messages": [{ "role": "user", "content": "Walk me through the full timeline of the January 15 outage from alert to full recovery." }]
}

###

# D2. Action items (last paragraph of task)
POST {{baseUrl}}/projects/{{projectId}}/chat?debug=true
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "messages": [{ "role": "user", "content": "What action items came out of the January 15 outage post-mortem?" }]
}

###

# ============================================================
# CATEGORY E — Strategy comparison (chunked vs single)
# Run both and compare _debug.retrieved scores.
# ============================================================

# E1. chunked
POST {{baseUrl}}/projects/{{projectId}}/chat?strategy=chunked&debug=true
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "messages": [{ "role": "user", "content": "What was the root cause of the auth token expiry bug?" }]
}

###

# E1. single — same query
POST {{baseUrl}}/projects/{{projectId}}/chat?strategy=single&debug=true
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "messages": [{ "role": "user", "content": "What was the root cause of the auth token expiry bug?" }]
}

###

# ============================================================
# CATEGORY F — Edge cases
# ============================================================

# F1. Answerable from task overview alone (no content needed)
POST {{baseUrl}}/projects/{{projectId}}/chat?debug=true
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "messages": [{ "role": "user", "content": "Which tasks are currently in progress?" }]
}

###

# F2. Unanswerable — fact not in any content
POST {{baseUrl}}/projects/{{projectId}}/chat?debug=true
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "messages": [{ "role": "user", "content": "What is the team's Figma file URL?" }]
}

###

# F3. Vague query
POST {{baseUrl}}/projects/{{projectId}}/chat?debug=true
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "messages": [{ "role": "user", "content": "Tell me about the project." }]
}

###

# ============================================================
# CATEGORY G — Gap coverage
# ============================================================

# G1. Ambiguous query — semantically matches multiple tasks
POST {{baseUrl}}/projects/{{projectId}}/chat?debug=true
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "messages": [{ "role": "user", "content": "What performance improvements were made this quarter?" }]
}

###

# G2. Cross-task synthesis — requires facts from 2 different tasks
POST {{baseUrl}}/projects/{{projectId}}/chat?debug=true
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "messages": [{ "role": "user", "content": "What did Bob Chen work on in February?" }]
}

###

# G3. Chunk boundary — answer straddles chunk 0/1 split
POST {{baseUrl}}/projects/{{projectId}}/chat?debug=true
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "messages": [{ "role": "user", "content": "What was Marcus Chen's schedule on his first day and what issue did he run into with Docker?" }]
}

###

# G4. False positive detection — answer exists in task description (overview)
POST {{baseUrl}}/projects/{{projectId}}/chat?debug=true
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "messages": [{ "role": "user", "content": "How long was the January 15 outage?" }]
}

###

# G5. Strategy comparison — multi-fact query (chunked)
POST {{baseUrl}}/projects/{{projectId}}/chat?strategy=chunked&debug=true
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "messages": [{ "role": "user", "content": "What were the load test results and what bottlenecks were found?" }]
}

###

# G5. Strategy comparison — same query (single)
POST {{baseUrl}}/projects/{{projectId}}/chat?strategy=single&debug=true
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "messages": [{ "role": "user", "content": "What were the load test results and what bottlenecks were found?" }]
}

