# ============================================================
# CATEGORY H — Long task strategy stress test (1,428w, ~12 chunks)
# Task: Atlas Core Service Registry — Technical Design
# ============================================================

# H1. Fact from early paragraph
POST {{baseUrl}}/projects/{{projectId}}/chat?debug=true
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "messages": [{ "role": "user", "content": "When was the Atlas Core service registry kickoff meeting and who attended?" }]
