DATABASE_URL="mongodb+srv://<your_username>:<your_password>@<your_cluster>.mongodb.net/"
DATABASE_NAME="fullstackTasks"
PORT=3001
JWT_SECRET=<your_jwt_secret>
JWT_ACCESS_EXPIRATION_TTL=86400
DEEPSEEK_API_KEY=<your_deepseek_api_key>
OPENAI_API_KEY=<your_openai_api_key>

# RAG / embedding settings (optional — defaults shown)
# Write side: one or more chunk versions to generate and store — each produces a separate set of embeddings in DB
CHUNK_CONFIGS=[{"size":150,"overlap":50},{"size":150,"overlap":25}]
# Read side: which stored chunk version to use for retrieval — must match one entry in CHUNK_CONFIGS
CHUNK_RETRIEVAL_CONFIG=150:50
# How long to wait (ms) after a content save before re-embedding
EMBEDDING_DEBOUNCE_MS=15000
